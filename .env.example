# ── Pocket Option ─────────────────────────────────────────────
# The URL you normally log in at. Adjust if your region differs.
PO_BASE_URL=https://pocketoption.com/en/login
# Where the trading terminal lives after login (used by the spike).
PO_CABINET_URL=https://pocketoption.com/en/cabinet

# ── Phase 1 spike ─────────────────────────────────────────────
# Headed vs headless for local runs (Phase 1 recommends headed).
HEADLESS=false
# How long the spike records frames before auto-summarizing (ms).
SPIKE_DURATION_MS=180000

# ── Streak detection (Phase 2) ────────────────────────────────
STREAK_THRESHOLD=7
TIMEFRAME_SEC=60
GRACE_SEC=1.5
BREAK_ON_DOJI=true

# ── Telegram alerts (Phase 2 — needed to send alerts) ─────────
# TELEGRAM_BOT_TOKEN=      # from BotFather
# TELEGRAM_CHAT_ID=        # your user/group/channel id

# ── (Later phases) ────────────────────────────────────────────
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # VPS scanner ONLY — never in the browser
# STREAK_THRESHOLD=7
